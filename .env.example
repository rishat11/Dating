# Telegram
BOT_TOKEN=your_bot_token_here

# Database: PostgreSQL (локально — Postgres в Docker, см. раздел «Запуск»)
# Локально: postgresql+asyncpg://dating:dating@localhost:5432/dating
# В Docker: задаётся в docker-compose.yml
DATABASE_URL=postgresql+asyncpg://dating:dating@localhost:5432/dating

# Redis (очередь и кэш). Локально: redis://localhost:6379 (поднять redis в Docker)
REDIS_URL=redis://localhost:6379

# Optional: DeepSeek API for PRO scenarios (analysis, secret question, etc.)
DEEPSEEK_API_KEY=

# Optional: URL for Privacy Policy (shown in Settings)
# PRIVACY_POLICY_URL=https://example.com/privacy

# Limits
DAILY_LIKES_LIMIT=10
DESTINY_INDEX_CACHE_TTL=3600
DESTINY_FREEZE_HOURS=3
SAVE_INDEX_SILENCE_HOURS=6
CHAT_MESSAGES_PER_MINUTE=30
FEED_REQUESTS_PER_MINUTE=20
MESSAGES_RETENTION_MONTHS=12
