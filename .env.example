# Telegram
BOT_TOKEN=your_bot_token_here

# Database (SQLite by default)
DATABASE_URL=sqlite+aiosqlite:///./dating.db

# Optional: Redis (cache + queue; if empty, in-memory fallback)
REDIS_URL=

# Optional: DeepSeek API for PRO scenarios (analysis, secret question, etc.)
DEEPSEEK_API_KEY=

# Limits
DAILY_LIKES_LIMIT=10
DESTINY_INDEX_CACHE_TTL=3600
DESTINY_FREEZE_HOURS=3
SAVE_INDEX_SILENCE_HOURS=6
CHAT_MESSAGES_PER_MINUTE=30
FEED_REQUESTS_PER_MINUTE=20
MESSAGES_RETENTION_MONTHS=12
